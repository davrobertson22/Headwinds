# Headwinds server environment — copy to .env and fill in.
# Local dev: put real values here. Production: set these in Railway (api + worker).

# ── Postgres (Supabase) ──────────────────────────────────────────────────────
# Supabase dashboard → "Connect" button → copy the Supavisor SESSION pooler string
# (ends in port 5432). Railway runs a persistent server, so the session pooler
# works for BOTH the running app and `prisma migrate` — use it for both vars.
# Replace [PROJECT-REF], [REGION], and [YOUR-PASSWORD] (your database password).
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"
# (If you ever move to a SERVERLESS host, switch DATABASE_URL to the TRANSACTION
#  pooler — same string but port 6543 — and keep DIRECT_URL on the 5432 string.)

# ── Supabase Auth ────────────────────────────────────────────────────────────
# Supabase dashboard → Project Settings → API.
SUPABASE_URL="https://[PROJECT-REF].supabase.co"
SUPABASE_ANON_KEY="[anon public key]"

# ── Server ───────────────────────────────────────────────────────────────────
PORT=8787
# Comma-separated list of allowed browser origins for CORS (the web client).
CORS_ORIGINS="http://localhost:5173"

# ── World spawner (worker) ───────────────────────────────────────────────────
# How often the worker tops up the pool of joinable worlds, in minutes.
SPAWN_INTERVAL_MINUTES=30
# Target number of recently-started PUBLIC worlds to keep available to join.
SPAWN_TARGET_OPEN_WORLDS=4
# A world counts as "young/joinable" if it started within this many hours.
SPAWN_YOUNG_THRESHOLD_HOURS=48
