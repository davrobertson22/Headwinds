// Headwinds — Phase 1 data model.
// See HEADWINDS_PHASE1_SCOPE.md §4 and HEADWINDS_MULTIPLAYER_PLAN.md §3a/§8.
//
// Authoritative state lives HERE (Postgres), never in server memory. The big
// per-airline save blob goes in Airline.state (JSONB) — the same JSON shape the
// solo game already serializes — with cash/marketCap/week promoted to columns for
// sorting and leaderboards.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled (pgBouncer) — used by the running app
  directUrl = env("DIRECT_URL") // direct connection — used by `prisma migrate`
}

enum WorldStatus {
  LOBBY
  RUNNING
  ENDED
  ARCHIVED
}

enum Visibility {
  PUBLIC
  PRIVATE
}

enum AirlineStatus {
  ACTIVE
  BANKRUPT
  ABANDONED
}

model Account {
  id          String    @id @default(cuid())
  authUserId  String    @unique // Supabase auth user id (token `sub`)
  email       String    @unique
  displayName String
  cosmetics   Json      @default("[]") // unlocked liveries/logos (meta-progression)
  careerStats Json      @default("{}") // cross-season hall-of-fame stats
  createdAt   DateTime  @default(now())
  // ── Moderation: a banned account cannot sign in / act (auth.mjs rejects it).
  // Set by an admin from the moderation panel; account-wide (blocks every world).
  bannedAt      DateTime?
  banReason     String?
  bannedByEmail String? // which admin issued the ban (audit trail)
  // ── OG veteran badge: playing since the original Tailwinds. Admin-granted
  // (players DM their email/Discord; an admin flips it from the moderation
  // panel). Account-wide: surfaces as a gold "✈ OG" chip beside every airline
  // this account flies, in every world — standings, Rivals tab, feed, messages.
  isOG Boolean @default(false)
  airlines    Airline[]
  reportsMade Report[]  @relation("ReportsMade")
  reportsAgainst Report[] @relation("ReportsAgainst")
}

model World {
  id          String      @id @default(cuid())
  name        String
  status      WorldStatus @default(LOBBY)
  visibility  Visibility  @default(PUBLIC)
  lengthYears Int // 50 | 100  (§3a)
  weeksPerDay Int // 6 | 12 | 24 | 48  (§3a)
  currentWeek Int         @default(1)
  currentYear Int         @default(1)
  maxPlayers  Int         @default(50)
  joinCode    String?     @unique // for PRIVATE worlds
  worldSeed   String // deterministic world generation
  tickConfig  Json        @default("{}")
  startedAt   DateTime?
  endsAt      DateTime? // derived: startedAt + lengthYears*52/weeksPerDay days
  createdAt   DateTime    @default(now())
  endedAt     DateTime?
  airlines    Airline[]
  standings   Standing[]
  ticks       TickLog[]
  decisions   Decision[]
  alliances   Alliance[]
  messages    Message[]
  reports     Report[]

  @@index([status, visibility])
}

model Airline {
  id          String        @id @default(cuid())
  worldId     String
  accountId   String
  name        String
  hub         String
  homeCountry String?
  state       Json // ← the existing solo save blob (JSONB)
  cash        BigInt        @default(0)
  marketCap   BigInt        @default(0)
  week        Int           @default(1)
  version     Int           @default(0) // optimistic-concurrency guard: tick vs player decision
  status      AirlineStatus @default(ACTIVE)
  joinedWeek  Int           @default(1)
  createdAt   DateTime      @default(now())
  world       World         @relation(fields: [worldId], references: [id], onDelete: Cascade)
  account     Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([worldId, accountId]) // one airline per account per world
  @@index([worldId, cash])
  @@index([worldId, marketCap]) // standings sort by marketCap DESC
}

// ── Phase-2-ready: created now, written when the tick lands ──────────────────

model Decision {
  id        String   @id @default(cuid())
  worldId   String
  airlineId String
  week      Int
  type      String // validated against the engine action allow-list
  payload   Json
  createdAt DateTime @default(now())
  world     World    @relation(fields: [worldId], references: [id], onDelete: Cascade)

  @@index([worldId, week])
  @@index([worldId, createdAt]) // world feed: filter worldId + type ORDER BY createdAt DESC
  @@index([airlineId, createdAt]) // rival profile: filter airlineId ORDER BY createdAt DESC
}

model TickLog {
  id         String    @id @default(cuid())
  worldId    String
  week       Int
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  status     String // ok | error
  error      String?
  world      World     @relation(fields: [worldId], references: [id], onDelete: Cascade)

  @@index([worldId, week])
}

// ── Player alliances (Headwinds has no AI blocs — alliances are founded and ──
// ── governed by players; founder approves join requests) ─────────────────────

enum AllianceMemberStatus {
  PENDING // asked to join, awaiting the founder
  ACTIVE // full member — benefits apply
}

enum AllianceMemberRole {
  FOUNDER
  MEMBER
}

model Alliance {
  id        String           @id @default(cuid())
  worldId   String
  name      String
  createdAt DateTime         @default(now())
  world     World            @relation(fields: [worldId], references: [id], onDelete: Cascade)
  members   AllianceMember[]

  @@unique([worldId, name]) // alliance names are unique within a world
}

model AllianceMember {
  id         String               @id @default(cuid())
  allianceId String
  airlineId  String               @unique // an airline belongs to at most ONE alliance (or has one pending request)
  status     AllianceMemberStatus @default(PENDING)
  role       AllianceMemberRole   @default(MEMBER)
  createdAt  DateTime             @default(now())
  alliance   Alliance             @relation(fields: [allianceId], references: [id], onDelete: Cascade)

  @@index([allianceId, status])
}

// ── In-game messaging: airline-to-airline DMs + alliance chat ─────────────────

enum MessageKind {
  DM // fromAirlineId → toAirlineId, readAt marks it read
  ALLIANCE // fromAirlineId → allianceId channel; read state via MessageCursor
}

model Message {
  id            String      @id @default(cuid())
  worldId       String
  kind          MessageKind @default(DM)
  fromAirlineId String
  toAirlineId   String? // DM recipient (null for alliance posts)
  allianceId    String? // alliance channel (null for DMs)
  body          String
  createdAt     DateTime    @default(now())
  readAt        DateTime? // DM read marker
  world         World       @relation(fields: [worldId], references: [id], onDelete: Cascade)

  @@index([worldId, toAirlineId, readAt]) // inbox + unread counts
  @@index([worldId, fromAirlineId, createdAt]) // rate limiting + sent view
  @@index([allianceId, createdAt]) // alliance channel feed
}

// "airlineId never wants to hear from blockedAirlineId again."
model MessageBlock {
  id               String   @id @default(cuid())
  airlineId        String
  blockedAirlineId String
  createdAt        DateTime @default(now())

  @@unique([airlineId, blockedAirlineId])
}

// Per-airline read cursor for channel-style feeds (alliance chat).
model MessageCursor {
  id             String    @id @default(cuid())
  airlineId      String    @unique
  allianceSeenAt DateTime?
}

// ── Player reports: one player flags another for a rule violation. An admin ──
// ── reviews these in the moderation panel and may ban the reported account. ──

enum ReportStatus {
  OPEN // awaiting an admin
  ACTIONED // admin acted (typically a ban)
  DISMISSED // admin judged it not actionable
}

model Report {
  id                String       @id @default(cuid())
  worldId           String
  // Who filed it (the account) and the airline they were flying as.
  reporterAccountId String
  reporterAirlineId String?
  // Who it's about — the ACCOUNT is what gets banned; the airline is context.
  reportedAccountId String
  reportedAirlineId String?
  category          String // HARASSMENT | CHEATING | OFFENSIVE_NAME | SPAM | OTHER
  details           String? // optional free-text from the reporter
  status            ReportStatus @default(OPEN)
  resolvedAt        DateTime?
  resolvedByEmail   String? // which admin resolved it
  resolutionNote    String? // e.g. "banned" / "dismissed — not actionable"
  createdAt         DateTime     @default(now())
  world             World        @relation(fields: [worldId], references: [id], onDelete: Cascade)
  reporter          Account      @relation("ReportsMade", fields: [reporterAccountId], references: [id], onDelete: Cascade)
  reported          Account      @relation("ReportsAgainst", fields: [reportedAccountId], references: [id], onDelete: Cascade)

  @@index([status, createdAt]) // the admin queue
  @@index([reportedAccountId]) // "all reports about this player"
  @@index([worldId])
}

model Standing {
  id        String   @id @default(cuid())
  worldId   String
  airlineId String
  week      Int
  rank      Int
  score     BigInt
  createdAt DateTime @default(now())
  world     World    @relation(fields: [worldId], references: [id], onDelete: Cascade)

  @@index([worldId, week, rank])
  @@index([airlineId, week]) // rank history: filter airlineId ORDER BY week DESC
}
