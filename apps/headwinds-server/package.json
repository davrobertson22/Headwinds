{
  "name": "@headwinds/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Headwinds multiplayer game server — Fastify API + worker, authoritative weekly tick over the shared @tailwinds/engine, persisted to Postgres via Prisma.",
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "scripts": {
    "dev": "node --watch src/server.mjs",
    "start": "node src/server.mjs",
    "worker": "node worker/index.mjs",
    "demo": "node demo.mjs",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@prisma/client": "^6.1.0",
    "@supabase/supabase-js": "^2.47.10",
    "@tailwinds/engine": "*",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.0"
  },
  "devDependencies": {
    "prisma": "^6.1.0"
  }
}
