# Headwinds web client environment — copy to .env.local and fill in.
# All three come from the same places as the server's .env:

# Supabase dashboard → Project Settings → API (same values as the server).
VITE_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
VITE_SUPABASE_ANON_KEY="[anon public key]"

# Where the @headwinds/server API is running.
# Local dev: the server's default port. Production: the Railway API URL.
VITE_API_URL="http://localhost:8787"
