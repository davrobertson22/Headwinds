{
  "name": "airline-management-game",
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test:cargo": "node tools/cargo-test.mjs",
    "test:multistop": "node tools/multistop-test.mjs",
    "test:multistop-edge": "node tools/multistop-edge-test.mjs",
    "test:multistop-reducer": "node tools/reducer-tag-test.mjs",
    "test:seasonal": "node tools/seasonal-test.mjs",
    "test:ui": "node --import ./tools/_register-loader.mjs tools/ui-smoke-test.mjs",
    "test:route-config": "node --import ./tools/_register-loader.mjs tools/route-config-test.mjs",
    "test": "node tools/cargo-test.mjs && node tools/multistop-test.mjs && node tools/multistop-edge-test.mjs && node tools/reducer-tag-test.mjs && node tools/seasonal-test.mjs && node --import ./tools/_register-loader.mjs tools/ui-smoke-test.mjs && node --import ./tools/_register-loader.mjs tools/route-config-test.mjs"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "@vitejs/plugin-react": "^4.3.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^5.4.0"
  },
  "engines": {
    "node": "20.x"
  }
}
